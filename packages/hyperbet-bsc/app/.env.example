VITE_SOLANA_CLUSTER=localnet
VITE_GAME_API_URL=http://127.0.0.1:5555
VITE_GAME_WS_URL=ws://127.0.0.1:5555/ws
VITE_STREAM_SOURCES=https://www.twitch.tv/hyperscapeai
VITE_BINARY_MARKET_MAKER_WALLET=
VITE_BINARY_TRADE_TREASURY_WALLET=
VITE_BINARY_TRADE_MARKET_MAKER_WALLET=
VITE_USE_GAME_RPC_PROXY=false
VITE_USE_GAME_EVM_RPC_PROXY=false

# Keep provider keys on the keeper service. Public builds must not set
# VITE_SOLANA_RPC_URL / VITE_BSC_RPC_URL / VITE_BASE_RPC_URL to keyed provider URLs.
VITE_SOLANA_RPC_URL=
VITE_BSC_RPC_URL=
VITE_BASE_RPC_URL=

# Legacy single-headless-wallet mode
VITE_HEADLESS_WALLET_SECRET_KEY=
VITE_HEADLESS_WALLET_NAME=Headless Test Wallet
VITE_HEADLESS_WALLET_AUTO_CONNECT=false

# Multi-headless-wallet mode (JSON array). Takes precedence when set.
# Example:
# VITE_HEADLESS_WALLETS=[{"name":"MM Wallet 1","secretKey":"<bs58-or-json-bytes>","autoConnect":true},{"name":"MM Wallet 2","secretKey":"<bs58-or-json-bytes>"}]
# Tip: generate this from market-maker config with
# `bun run --cwd /Users/shawwalters/eliza-workspace/hyperbet/packages/market-maker-bot wallets:ui-env -- --config wallets.generated.json --out ../hyperbet-bsc/app/.env.local`
VITE_HEADLESS_WALLETS=

# Optional contract / RPC overrides.
# When omitted, the app falls back to packages/hyperbet-bsc/deployments/contracts.json.
VITE_FIGHT_ORACLE_PROGRAM_ID=
VITE_GOLD_CLOB_MARKET_PROGRAM_ID=
VITE_GOLD_PERPS_MARKET_PROGRAM_ID=
VITE_BSC_RPC_URL=
VITE_BSC_CHAIN_ID=
VITE_BSC_GOLD_CLOB_ADDRESS=
VITE_BSC_GOLD_TOKEN_ADDRESS=
VITE_BASE_RPC_URL=
VITE_BASE_CHAIN_ID=
VITE_BASE_GOLD_CLOB_ADDRESS=
VITE_BASE_GOLD_TOKEN_ADDRESS=
