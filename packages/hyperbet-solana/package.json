{
  "name": "@hyperbet/hyperbet-solana",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "anchor:build": "bun run --cwd anchor build",
    "anchor:deploy:mainnet": "bun run --cwd anchor deploy:mainnet",
    "anchor:deploy:pm:devnet": "bun run --cwd anchor deploy:pm:devnet",
    "anchor:deploy:pm:testnet": "bun run --cwd anchor deploy:pm:testnet",
    "anchor:deploy:pm:mainnet": "bun run --cwd anchor deploy:pm:mainnet",
    "anchor:deploy:testnet": "bun run --cwd anchor deploy:testnet",
    "anchor:test": "bun run --cwd anchor test",
    "deploy:preflight:mainnet": "bun run scripts/preflight-contract-deploy.ts --target mainnet",
    "deploy:preflight:mainnet:pm": "bun run scripts/preflight-contract-deploy.ts --target mainnet --pm-only",
    "deploy:preflight:testnet": "bun run scripts/preflight-contract-deploy.ts --target testnet",
    "deploy:preflight:testnet:pm": "bun run scripts/preflight-contract-deploy.ts --target testnet --pm-only",
    "deploy:preflight:devnet:pm": "bun run scripts/preflight-contract-deploy.ts --cluster devnet --pm-only",
    "deploy:pm:init:devnet": "node --import tsx scripts/init-pm-config.ts --cluster devnet",
    "deploy:pm:init:testnet": "node --import tsx scripts/init-pm-config.ts --cluster testnet",
    "verify:deployment:devnet:pm": "node --import tsx scripts/verify-deployment.ts --cluster devnet --pm-only",
    "verify:deployment:testnet:pm": "node --import tsx scripts/verify-deployment.ts --cluster testnet --pm-only",
    "codegen:clients": "bunx coda generate -c ./coda/fight-oracle.config.mjs && bunx coda generate -c ./coda/gold-clob-market.config.mjs && bunx coda generate -c ./coda/gold-perps-market.config.mjs",
    "sync:anchor-artifacts": "node scripts/sync-anchor-artifacts.mjs",
    "dev": "bun run --cwd app dev --mode devnet",
    "dev:local": "bash app/scripts/run-local-demo.sh",
    "dev:devnet": "bun run --cwd app dev --mode devnet",
    "dev:stream-ui": "bun run --cwd app dev --mode stream-ui",
    "dev:app-local": "bun run --cwd app dev --mode local",
    "dev:testnet": "bun run --cwd app dev --mode testnet",
    "dev:mainnet": "bun run --cwd app dev --mode mainnet",
    "build": "bun run --cwd app build",
    "build:testnet": "bun run --cwd app build --mode testnet",
    "build:mainnet": "bun run --cwd app build --mode mainnet",
    "preview": "bun run --cwd app preview",
    "test:e2e:local": "bun run --cwd app test:e2e:local",
    "test:e2e:testnet": "bun run --cwd app test:e2e:testnet",
    "test:e2e:mainnet": "bun run --cwd app test:e2e:mainnet",
    "keeper:bot": "bun run --cwd keeper bot",
    "keeper:bot:mainnet": "SOLANA_CLUSTER=mainnet-beta bun run --cwd keeper bot",
    "keeper:bot:testnet": "SOLANA_CLUSTER=testnet bun run --cwd keeper bot",
    "keeper:bot:devnet": "SOLANA_CLUSTER=devnet bun run --cwd keeper bot",
    "keeper:bot:once": "bun run --cwd keeper bot -- --once",
    "keeper:service": "bun run --cwd keeper service",
    "keeper:seed": "bun run --cwd keeper seed",
    "keeper:resolve": "bun run --cwd keeper resolve"
  },
  "dependencies": {
    "@hyperbet/chain-registry": "workspace:*",
    "@hyperbet/mm-core": "workspace:*",
    "@coral-xyz/anchor": "^0.32.1",
    "@noble/curves": "^2.0.1",
    "@solana/wallet-adapter-phantom": "^0.9.28",
    "@solana/wallet-adapter-react": "^0.15.39",
    "@solana/wallet-adapter-react-ui": "^0.9.39",
    "@solana/web3.js": "^1.98.4",
    "@tanstack/react-query": "^5.90.21",
    "bn.js": "5.2.2",
    "@vitejs/plugin-react": "^5.1.4"
  },
  "devDependencies": {
    "@macalinao/coda": "^0.4.10",
    "@types/bn.js": "5.2.0",
    "tsx": "^4.21.0"
  }
}
