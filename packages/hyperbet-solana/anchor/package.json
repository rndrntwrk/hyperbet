{
  "name": "hyperbet-solana-anchor",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bash scripts/build-workspace.sh",
    "deploy:devnet": "bash scripts/deploy-programs.sh devnet",
    "deploy:testnet": "bash scripts/deploy-programs.sh testnet",
    "deploy:mainnet": "bash scripts/deploy-programs.sh mainnet-beta",
    "lint:rust": "cargo clippy --workspace --all-targets --all-features -- -D warnings",
    "test:rust": "cargo test --workspace",
    "audit": "bash scripts/run-cargo-audit.sh",
    "audit:strict": "ANCHOR_AUDIT_STRICT=1 bash scripts/run-cargo-audit.sh -D warnings",
    "test": "bash scripts/run-localnet-tests.sh tests/black_hat_exploits.ts tests/gold-betting-demo.ts tests/gold_clob_market.test.ts tests/gold_clob_security.ts tests/gold_perps_market.ts",
    "test:anchor-cli": "if command -v anchor >/dev/null 2>&1; then HYPERSCAPE_MAX_ORACLE_STALENESS_SECONDS=1 GOLD_PERPS_TEST_STALE_WAIT_MS=2500 anchor test; else echo 'Anchor CLI not found, skipping tests'; fi",
    "simulate:localnet": "node scripts/run-hyperscape-simulation.mjs",
    "simulate:perps-risk": "bun scripts/simulate-gold-perps-risk.ts"
  },
  "devDependencies": {
    "@coral-xyz/anchor": "0.32.1",
    "@solana/spl-token": "0.4.14",
    "@solana/web3.js": "1.98.4",
    "@types/bn.js": "^5.2.0",
    "@types/chai": "5.2.3",
    "@types/mocha": "10.0.10",
    "bn.js": "^5.2.3",
    "chai": "6.2.2",
    "mocha": "10.8.2",
    "ts-mocha": "10.0.0",
    "typescript": "5.9.3"
  }
}
